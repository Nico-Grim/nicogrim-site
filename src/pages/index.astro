---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  { name: 'Pinned.', de: 'Travel Tracker — Länder, Städte & Reisen tracken', en: 'Travel Tracker — track countries, cities & trips', url: '/pinned' },
  { name: 'BRP Deutsch', de: 'Lern-App für die Deutsch-Matura', en: 'Study app for the German Matura exam', url: 'https://deutsch-matura.nico-grim.me' },
  { name: 'BRP Mathe', de: 'Lern-App für die Mathe-Matura', en: 'Study app for the Math Matura exam', url: null },
  { name: 'Daily Tools', de: '20+ Browser-Tools, kostenlos, ohne Anmeldung', en: '20+ browser tools, free, no signup', url: null },
  { name: 'Taskly', de: 'Einfache Todo-App mit Listen, Subtasks & Erinnerungen', en: 'Simple todo app with lists, subtasks & reminders', url: '/taskly' },
  { name: 'FLACON', de: 'Parfum-Sammlungs-App', en: 'Perfume collection app', url: null },
];


---

<BaseLayout title="Home" description="Nico Grim — Apps, Tools & digitale Produkte aus Wien. Pinned. Travel Tracker, BRP Lern-Apps, Daily Tools und mehr.">
  <div class="mx-auto max-w-[620px] px-6">

    <!-- Language toggle -->
    <div class="flex justify-end pt-6">
      <button id="lang-toggle" class="text-sm text-text-3 hover:text-text-2 transition-colors cursor-pointer">
        EN
      </button>
    </div>

    <!-- Hero -->
    <header class="pt-14 pb-20 sm:pt-24 sm:pb-28">
      <h1 class="font-display text-[clamp(3rem,10vw,6.5rem)] leading-[0.95] tracking-tight">
        Nico<br/>Grim
      </h1>
      <p class="mt-5 text-lg text-text-2 leading-relaxed max-w-[400px]" data-de="Ich baue Apps, Tools &amp; digitale Produkte in Wien." data-en="Building apps, tools &amp; digital products in Vienna."></p>
    </header>

    <!-- Featured Apps -->
    <section class="pb-10 sm:pb-12">
      <h2 class="text-xs text-text-3 tracking-widest uppercase mb-6" data-de="Projekte" data-en="Projects"></h2>
      <div class="space-y-3">
        <a href="/pinned" class="group flex items-center gap-5 rounded-xl border border-border bg-surface p-4 sm:p-5 transition-all hover:border-text-3 hover:bg-surface-hover">
          <img src="/images/pinned/icon.png" alt="Pinned." class="w-14 h-14 sm:w-16 sm:h-16 rounded-xl shrink-0" />
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2.5">
              <span class="font-display text-xl sm:text-2xl text-text group-hover:text-link-hover transition-colors">Pinned.</span>
              <span class="rounded-full bg-[#34a853]/15 text-[#34a853] text-[11px] px-2 py-0.5" data-de="Bald verfügbar" data-en="Coming soon"></span>
            </div>
            <p class="text-text-2 text-sm mt-0.5" data-de="Travel Tracker — Länder, Städte &amp; Reisen tracken" data-en="Travel Tracker — track countries, cities &amp; trips"></p>
          </div>
          <span class="text-text-3 group-hover:text-text-2 group-hover:translate-x-0.5 transition-all shrink-0 text-lg">→</span>
        </a>
        <a href="/taskly" class="group flex items-center gap-5 rounded-xl border border-border bg-surface p-4 sm:p-5 transition-all hover:border-text-3 hover:bg-surface-hover">
          <img src="/images/taskly-icon.png" alt="Taskly" class="w-14 h-14 sm:w-16 sm:h-16 rounded-xl shrink-0" />
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2.5">
              <span class="font-display text-xl sm:text-2xl text-text group-hover:text-link-hover transition-colors">Taskly</span>
              <span class="rounded-full bg-[#34a853]/15 text-[#34a853] text-[11px] px-2 py-0.5" data-de="Bald verfügbar" data-en="Coming soon"></span>
            </div>
            <p class="text-text-2 text-sm mt-0.5" data-de="Einfache Todo-App mit Listen, Subtasks &amp; Erinnerungen" data-en="Simple todo app with lists, subtasks &amp; reminders"></p>
          </div>
          <span class="text-text-3 group-hover:text-text-2 group-hover:translate-x-0.5 transition-all shrink-0 text-lg">→</span>
        </a>
      </div>
    </section>

    <!-- Other Projects -->
    <section class="pb-20 sm:pb-28">
      <div class="space-y-3">
        {projects.filter(p => p.name !== 'Pinned.' && p.name !== 'Taskly').map((p) => {
          const isExternal = p.url?.startsWith('http');
          return (
            <a
              href={p.url || undefined}
              {...(isExternal ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              class:list={[
                'flex items-center justify-between rounded-xl border border-border bg-surface p-4 sm:p-5 transition-all',
                p.url ? 'group hover:border-text-3 hover:bg-surface-hover cursor-pointer' : 'opacity-60',
              ]}
            >
              <div>
                <span class="font-medium text-text group-hover:text-link-hover transition-colors">{p.name}</span>
                <p class="text-text-2 text-sm mt-0.5" data-de={p.de} data-en={p.en}></p>
              </div>
              {p.url && (
                <span class="text-text-3 group-hover:text-text-2 group-hover:translate-x-0.5 transition-all shrink-0 ml-4 text-lg">
                  {isExternal ? '↗' : '→'}
                </span>
              )}
            </a>
          );
        })}
      </div>
      <p class="text-text-3 text-sm mt-6" data-de="Mehr in Arbeit." data-en="More in the works."></p>
    </section>

    <!-- About -->
    <section class="pb-20 sm:pb-28">
      <h2 class="text-xs text-text-3 tracking-widest uppercase mb-4" data-de="Über mich" data-en="About"></h2>
      <p class="text-text-2 leading-relaxed" data-de="Self-taught Developer aus Wien. Ich baue Apps und Tools die ich selbst nutzen will — und veröffentliche sie für alle. Aktuell arbeite ich an Pinned., einem Travel Tracker für Android &amp; iOS." data-en="Self-taught developer from Vienna. I build apps and tools that I want to use myself — and release them for everyone. Currently working on Pinned., a travel tracker for Android &amp; iOS."></p>
    </section>

    <!-- Contact -->
    <section class="pb-20 sm:pb-28">
      <h2 class="text-xs text-text-3 tracking-widest uppercase mb-6" data-de="Kontakt" data-en="Contact"></h2>
      <div class="space-y-2">
        <a href="mailto:hello@nicogrim.com" class="block text-text-2 hover:text-link-hover transition-colors">hello@nicogrim.com</a>
        <a href="https://github.com/Nico-Grim" target="_blank" rel="noopener noreferrer" class="block text-text-2 hover:text-link-hover transition-colors">GitHub ↗</a>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-border py-8 flex flex-wrap items-center justify-between gap-4 text-sm text-text-3">
      <span>&copy; 2026 Nico Grim</span>
      <nav class="flex gap-5">
        <a href="/impressum" class="hover:text-text-2 transition-colors">Impressum</a>
        <a href="/datenschutz" class="hover:text-text-2 transition-colors">Datenschutz</a>
      </nav>
    </footer>

  </div>
</BaseLayout>

<script>
  const toggle = document.getElementById('lang-toggle')!;
  const els = document.querySelectorAll<HTMLElement>('[data-de]');

  function setLang(lang: 'de' | 'en') {
    els.forEach((el) => {
      el.innerHTML = el.dataset[lang] || '';
    });
    toggle.textContent = lang === 'de' ? 'EN' : 'DE';
    document.documentElement.lang = lang;
    localStorage.setItem('lang', lang);
  }

  // Init: saved preference > browser language > default deutsch
  const saved = localStorage.getItem('lang') as 'de' | 'en' | null;
  const browserDe = navigator.language.startsWith('de');
  const initial = saved || (browserDe ? 'de' : 'en');
  setLang(initial);

  toggle.addEventListener('click', () => {
    setLang(document.documentElement.lang === 'de' ? 'en' : 'de');
  });
</script>
