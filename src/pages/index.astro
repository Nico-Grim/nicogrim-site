---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');
const featured = allProducts
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Nico Grim',
  url: 'https://nicogrim.com',
  jobTitle: 'Developer & Creator',
  sameAs: ['https://github.com/nicogrim', 'https://x.com/nicogrim', 'https://linkedin.com/in/nicogrim'],
};

const statusText: Record<string, string> = {
  development: 'In Development', beta: 'Beta', live: 'Live', discontinued: 'Discontinued',
};

// Each product gets its own color world
const productColors: Record<string, { bg: string; accent: string; glow: string }> = {
  'friends-app': { bg: '#0f1628', accent: '#4f8eff', glow: 'rgba(79,142,255,0.08)' },
  'daily-tools': { bg: '#0d1a12', accent: '#3dd68c', glow: 'rgba(61,214,140,0.08)' },
  'brp-study-app': { bg: '#1a1410', accent: '#e8a64a', glow: 'rgba(232,166,74,0.08)' },
};
---

<BaseLayout title="Home" jsonLd={jsonLd}>

  <!-- Hero — fullscreen, atmospheric -->
  <section class="relative -mt-16 flex min-h-[100svh] items-center justify-center overflow-hidden">
    <div class="absolute inset-0 hero-bg"></div>
    <div class="relative text-center px-6 max-w-3xl">
      <h1 class="animate-in text-[clamp(2.4rem,6vw,4.5rem)] font-extrabold leading-[1.08] tracking-tight">
        Apps, Tools &amp; Digital<br/>Products by Nico Grim
      </h1>
      <p class="animate-in delay-1 mt-5 text-lg text-text-secondary mx-auto max-w-md">
        Developer in Vienna. I build things for people to use.
      </p>
      <div class="animate-in delay-2 mt-8">
        <a href="#work" class="inline-flex items-center gap-2 rounded-full bg-accent px-7 py-3 text-sm font-semibold text-white hover:bg-accent-light transition-colors">
          See my work
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
        </a>
      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 scroll-hint">
      <div class="w-5 h-8 rounded-full border-2 border-text-muted/30 flex justify-center pt-1.5">
        <div class="w-1 h-1.5 rounded-full bg-text-muted/50 animate-scroll-dot"></div>
      </div>
    </div>
  </section>

  <!-- Products — each gets its own full-bleed section with unique color -->
  <section id="work">
    {featured.map((product, i) => {
      const colors = productColors[product.id] || { bg: '#111116', accent: '#e8643a', glow: 'rgba(232,100,58,0.08)' };
      return (
        <a
          href={`/products/${product.id}`}
          class="product-section group relative block overflow-hidden"
          style={`background-color: ${colors.bg};`}
          data-animate
        >
          <!-- Full-bleed image area -->
          <div class="relative aspect-[16/7] sm:aspect-[2.5/1] overflow-hidden">
            {product.data.heroImage ? (
              <img
                src={product.data.heroImage}
                alt={product.data.name}
                class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.03]"
              />
            ) : (
              <div class="absolute inset-0 flex items-center justify-center" style={`background: linear-gradient(135deg, ${colors.bg}, ${colors.glow});`}>
                <span class="text-[min(20vw,250px)] font-black leading-none select-none" style={`color: ${colors.accent}; opacity: 0.12;`}>
                  {product.data.name.charAt(0)}
                </span>
              </div>
            )}
            <!-- Bottom fade into info area -->
            <div class="absolute bottom-0 left-0 right-0 h-1/3" style={`background: linear-gradient(to top, ${colors.bg}, transparent);`}></div>
          </div>

          <!-- Product info -->
          <div class="relative container-main py-8 sm:py-10 -mt-16 sm:-mt-20">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <div class="flex items-center gap-3 mb-3">
                  <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium" style={`background: ${colors.accent}20; color: ${colors.accent};`}>
                    {product.data.category}
                  </span>
                  <span class="text-sm" style={`color: ${colors.accent}99;`}>{statusText[product.data.status]}</span>
                </div>
                <h2 class="text-3xl font-bold text-white sm:text-4xl transition-colors duration-300" style={`--hover-color: ${colors.accent};`}>
                  {product.data.name}
                </h2>
                <p class="mt-2 text-lg text-white/50 max-w-lg">{product.data.tagline}</p>
              </div>
              <div class="flex items-center gap-2 text-sm font-medium transition-all duration-300 group-hover:gap-3 shrink-0" style={`color: ${colors.accent};`}>
                Explore
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </div>
            </div>
          </div>
        </a>
      );
    })}
  </section>

  <!-- About — warm, personal -->
  <section class="py-24 sm:py-32">
    <div class="container-main">
      <div class="max-w-2xl mx-auto text-center" data-animate>
        <h2 class="text-3xl font-bold sm:text-4xl">About</h2>
        <p class="mt-5 text-lg text-text-secondary leading-relaxed">
          I'm Nico — a self-taught developer from Vienna. I've been building things on the web for a few years. I like when the result is something people enjoy using, and I care about the details that make that happen.
        </p>
        <div class="mt-6 flex flex-wrap justify-center gap-5 text-sm">
          <a href="/about" class="text-text-secondary hover:text-accent transition-colors">More about me &rarr;</a>
          <a href="mailto:hello@nicogrim.com" class="text-text-secondary hover:text-accent transition-colors">hello@nicogrim.com</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .hero-bg {
    background:
      radial-gradient(ellipse 80% 60% at 50% 40%, rgba(232,100,58,0.06), transparent),
      radial-gradient(ellipse 60% 50% at 20% 80%, rgba(79,142,255,0.04), transparent),
      var(--color-bg);
  }

  .product-section h2 {
    transition: color 0.3s;
  }
  .product-section:hover h2 {
    color: var(--hover-color, var(--color-accent));
  }

  .animate-scroll-dot {
    animation: scrollDot 1.8s ease-in-out infinite;
  }

  @keyframes scrollDot {
    0%, 100% { transform: translateY(0); opacity: 0.5; }
    50% { transform: translateY(8px); opacity: 1; }
  }

  .scroll-hint {
    animation: fadeIn 1s 1.5s both;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
