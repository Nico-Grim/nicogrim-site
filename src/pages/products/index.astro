---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProducts = await getCollection('products');
const products = allProducts.sort((a, b) => new Date(b.data.releaseDate).getTime() - new Date(a.data.releaseDate).getTime());

const categories = ['all', 'app', 'game', 'tool', 'website'] as const;
const statusText: Record<string, string> = {
  development: 'In Development', beta: 'Beta', live: 'Live', discontinued: 'Discontinued',
};

const productColors: Record<string, { bg: string; accent: string }> = {
  'friends-app': { bg: '#0f1628', accent: '#4f8eff' },
  'daily-tools': { bg: '#0d1a12', accent: '#3dd68c' },
  'brp-study-app': { bg: '#1a1410', accent: '#e8a64a' },
};
---

<BaseLayout title="Products" description="Apps, tools, games, and websites built by Nico Grim.">
  <section class="pt-12 sm:pt-20 pb-8">
    <div class="container-main">
      <h1 class="animate-in text-4xl font-bold tracking-tight sm:text-5xl">Products</h1>
      <p class="animate-in delay-1 mt-3 text-lg text-text-secondary max-w-lg">
        Things I've built — from mobile apps to browser tools.
      </p>

      <div class="animate-in delay-2 mt-8 flex flex-wrap gap-2" id="filter-bar">
        {categories.map((cat) => (
          <button
            data-filter={cat}
            class:list={[
              'filter-btn rounded-md px-3.5 py-1.5 text-sm transition-colors',
              cat === 'all' ? 'bg-text text-bg' : 'text-text-muted hover:text-text',
            ]}
          >
            {cat === 'all' ? 'All' : cat.charAt(0).toUpperCase() + cat.slice(1) + 's'}
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="pb-24">
    <div class="space-y-6" id="products-grid">
      {products.map((product) => {
        const colors = productColors[product.id] || { bg: '#151517', accent: '#e8643a' };
        return (
          <a
            href={`/products/${product.id}`}
            class="product-item group block"
            data-category={product.data.category}
            data-animate
          >
            <div class="relative overflow-hidden" style={`background: ${colors.bg};`}>
              <div class="aspect-[16/7] sm:aspect-[3/1] overflow-hidden">
                {product.data.heroImage ? (
                  <img src={product.data.heroImage} alt={product.data.name} class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.02]" />
                ) : (
                  <div class="flex h-full items-center justify-center">
                    <span class="text-[min(18vw,200px)] font-black leading-none select-none" style={`color: ${colors.accent}; opacity: 0.1;`}>{product.data.name.charAt(0)}</span>
                  </div>
                )}
                <div class="absolute bottom-0 left-0 right-0 h-1/2" style={`background: linear-gradient(to top, ${colors.bg}, transparent);`}></div>
              </div>
              <div class="container-main relative -mt-14 pb-8">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
                  <div>
                    <div class="flex items-center gap-3 mb-2">
                      <span class="text-xs font-medium rounded-full px-2.5 py-0.5" style={`background: ${colors.accent}20; color: ${colors.accent};`}>{product.data.category}</span>
                      <span class="text-sm" style={`color: ${colors.accent}88;`}>{statusText[product.data.status]}</span>
                    </div>
                    <h2 class="text-2xl font-bold text-white sm:text-3xl">{product.data.name}</h2>
                    <p class="mt-1 text-white/45">{product.data.tagline}</p>
                  </div>
                  <span class="text-sm font-medium shrink-0 group-hover:translate-x-1 transition-transform" style={`color: ${colors.accent};`}>
                    View &rarr;
                  </span>
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <div id="empty-state" class="hidden container-main py-20 text-center text-text-muted">Nothing here yet.</div>
  </section>
</BaseLayout>

<script>
  const btns = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.product-item');
  const empty = document.getElementById('empty-state');

  btns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const f = btn.getAttribute('data-filter');
      btns.forEach((b) => { b.classList.remove('bg-text', 'text-bg'); b.classList.add('text-text-muted'); });
      btn.classList.add('bg-text', 'text-bg'); btn.classList.remove('text-text-muted');
      let n = 0;
      items.forEach((el) => {
        const show = f === 'all' || (el as HTMLElement).dataset.category === f;
        (el as HTMLElement).style.display = show ? '' : 'none';
        if (show) n++;
      });
      empty?.classList.toggle('hidden', n > 0);
    });
  });
  const p = new URLSearchParams(window.location.search).get('category');
  if (p) (document.querySelector(`[data-filter="${p}"]`) as HTMLElement)?.click();
</script>
