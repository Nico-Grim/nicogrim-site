---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404">
  <div class="mx-auto max-w-[620px] px-6 pt-32 pb-20 text-center">
    <h1 class="font-display text-8xl text-text-3">404</h1>
    <p class="mt-4 text-text-2" data-de="Diese Seite gibt es nicht." data-en="This page doesn't exist."></p>
    <a href="/" class="inline-block mt-6 text-sm text-text-3 hover:text-text-2 transition-colors">&larr; <span data-de="Zurück zur Startseite" data-en="Back to homepage"></span></a>
  </div>
</BaseLayout>

<script>
  const els = document.querySelectorAll<HTMLElement>('[data-de]');
  const saved = localStorage.getItem('lang') as 'de' | 'en' | null;
  const browserDe = navigator.language.startsWith('de');
  const lang = saved || (browserDe ? 'de' : 'en');
  document.documentElement.lang = lang;
  els.forEach((el) => { el.innerHTML = el.dataset[lang] || ''; });
</script>
