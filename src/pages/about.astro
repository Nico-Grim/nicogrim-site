---
import BaseLayout from '../layouts/BaseLayout.astro';

const tools = ['TypeScript', 'React', 'Tailwind CSS', 'Astro', 'Next.js', 'Node.js', 'Supabase', 'PostgreSQL', 'Capacitor', 'Git', 'Vercel', 'Figma'];
---

<BaseLayout title="About" description="About Nico Grim — developer and creator based in Vienna, Austria.">
  <section class="pt-12 sm:pt-20">
    <div class="container-main">
      <div class="max-w-[640px]">
        <h1 class="animate-in text-4xl font-bold tracking-tight sm:text-5xl">About</h1>

        <div class="animate-in delay-1 mt-8 space-y-5 text-lg text-text-secondary leading-relaxed">
          <p>
            I'm Nico, a developer based in Vienna. I build apps, tools, and websites — mostly for the web, sometimes native.
          </p>
          <p>
            I'm self-taught and started a few years ago with basic HTML projects. Since then I've shipped learning apps, utility tools, and I'm currently building a social app for friend groups. I like figuring things out and I like when the result is something people actually want to use.
          </p>
          <p>
            I care about how things work <em>and</em> how they feel. Good software isn't just functional — it should be pleasant to interact with. That goes for the code too.
          </p>
          <p>
            When I'm not building, I'm probably reading, walking around Vienna, or starting yet another side project.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools -->
  <section class="py-20 sm:py-28">
    <div class="container-main">
      <div class="border-t border-border pt-10" data-animate>
        <p class="text-sm text-text-muted mb-6">Tools I use</p>
        <div class="flex flex-wrap gap-2.5">
          {tools.map((t) => (
            <span class="rounded-md border border-border px-3 py-1.5 text-sm text-text-secondary">{t}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="pb-20 sm:pb-28">
    <div class="container-main">
      <div class="border-t border-border pt-10" data-animate>
        <p class="text-sm text-text-muted mb-8">Timeline</p>
        <div class="space-y-8 max-w-[520px]">
          <div>
            <p class="text-sm text-text-muted">2025</p>
            <p class="mt-1 text-text">Building Friends App, maintaining existing projects, redesigning my portfolio.</p>
          </div>
          <div>
            <p class="text-sm text-text-muted">2024</p>
            <p class="mt-1 text-text">Launched Daily Tools and the BRP Study App. Got serious about shipping.</p>
          </div>
          <div>
            <p class="text-sm text-text-muted">2023</p>
            <p class="mt-1 text-text">Went deep on TypeScript, React, and Tailwind. Started building real projects.</p>
          </div>
          <div>
            <p class="text-sm text-text-muted">2022</p>
            <p class="mt-1 text-text">First web projects. Figured out HTML, CSS, JS. Got hooked.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="container-main" data-animate>
      <div class="border-t border-border pt-10 max-w-[520px]">
        <p class="text-text-secondary">
          Want to work together? <a href="mailto:hello@nicogrim.com" class="text-text underline underline-offset-2 hover:text-accent transition-colors">Drop me an email</a> or find me on <a href="https://github.com/nicogrim" target="_blank" rel="noopener noreferrer" class="text-text underline underline-offset-2 hover:text-accent transition-colors">GitHub</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
