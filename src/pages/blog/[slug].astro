---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, date, excerpt, tags } = post.data;
---

<BaseLayout title={title} description={excerpt}>
  <article class="pt-8 sm:pt-14 pb-20">
    <div class="container-main">
      <a href="/blog" class="animate-in text-sm text-text-muted hover:text-text transition-colors">&larr; Blog</a>

      <header class="mt-6 mb-10 max-w-2xl">
        <time datetime={date} class="animate-in delay-1 text-sm text-text-muted">
          {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <h1 class="animate-in delay-2 mt-2 text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
        {tags.length > 0 && (
          <div class="animate-in delay-3 mt-3 flex gap-2">
            {tags.map((tag) => (
              <span class="text-sm text-text-muted">#{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="prose-custom max-w-2xl">
        <Content />
      </div>

      <div class="mt-14 border-t border-border pt-6">
        <a href="/blog" class="text-sm text-text-muted hover:text-accent transition-colors">&larr; All posts</a>
      </div>
    </div>
  </article>
</BaseLayout>
