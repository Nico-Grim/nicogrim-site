---
interface Props {
  product: {
    id: string;
    data: {
      name: string;
      tagline: string;
      category: 'app' | 'game' | 'tool' | 'website';
      status: 'development' | 'beta' | 'live' | 'discontinued';
      heroImage?: string;
      techStack: string[];
    };
  };
}

const { product } = Astro.props;
const { name, tagline, category, status, heroImage, techStack } = product.data;

const categoryLabels: Record<string, string> = {
  app: 'App', game: 'Game', tool: 'Tool', website: 'Website',
};
const statusLabels: Record<string, string> = {
  development: 'In Development', beta: 'Beta', live: 'Live', discontinued: 'Discontinued',
};
---

<a href={`/products/${product.id}`} class="card group flex flex-col overflow-hidden">
  <!-- Thumbnail -->
  <div class="relative aspect-[16/10] bg-gradient-to-br from-bg-tertiary to-surface overflow-hidden">
    {heroImage ? (
      <img src={heroImage} alt={name} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
    ) : (
      <div class="flex h-full items-center justify-center">
        <span class="text-3xl font-bold text-text-muted/30">{name.charAt(0)}</span>
      </div>
    )}
    <div class="absolute top-3 left-3 flex gap-2">
      <span class={`badge-${category}`}>{categoryLabels[category]}</span>
    </div>
  </div>

  <!-- Content -->
  <div class="flex flex-1 flex-col p-5">
    <div class="flex items-start justify-between gap-2">
      <h3 class="text-lg font-semibold text-text group-hover:text-accent transition-colors">{name}</h3>
      <span class={`badge-status-${status} shrink-0 text-[11px]`}>{statusLabels[status]}</span>
    </div>
    <p class="mt-1.5 text-sm text-text-secondary line-clamp-2">{tagline}</p>
    <div class="mt-auto pt-4 flex flex-wrap gap-1.5">
      {techStack.slice(0, 4).map((tech) => (
        <span class="rounded-md bg-bg-tertiary px-2 py-0.5 text-[11px] text-text-muted">{tech}</span>
      ))}
      {techStack.length > 4 && (
        <span class="rounded-md bg-bg-tertiary px-2 py-0.5 text-[11px] text-text-muted">+{techStack.length - 4}</span>
      )}
    </div>
  </div>
</a>
